# =============================================================================
# Voice Memory Assistant — backend environment
# =============================================================================

# --- LiveKit ---
# v2.0 DEFAULT: self-hosted local server (docker compose up).
# Use your Mac's LAN IP (not localhost) so a physical iPhone can connect.
# Find it with: ipconfig getifaddr en0
LIVEKIT_URL=ws://192.168.1.104:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace-with-the-secret-in-livekit.yaml

# (v1.0 cloud option — still works, just swap these back in:)
# LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
# LIVEKIT_API_KEY=APIxxxxxxxxxxxx
# LIVEKIT_API_SECRET=your-livekit-cloud-secret

# (Single-VM production: this is the PUBLIC URL the token server hands to the
# app. iOS requires wss in production — terminate TLS with Caddy on your domain.
# LIVEKIT_API_KEY/SECRET are also fed to the SFU via LIVEKIT_KEYS in
# docker-compose.prod.yml.)
# LIVEKIT_URL=wss://api.example.com

# --- Deepgram (STT + Aura TTS): https://console.deepgram.com ---
DEEPGRAM_API_KEY=your-deepgram-api-key

# --- Groq (LLM): https://console.groq.com/keys  (free tier) ---
GROQ_API_KEY=gsk_your-groq-api-key

# --- Notes store ---
# The store auto-selects its backend (see backend/store.py NotesStore.from_env):
#   * If DB_URL (or DB_POOL_URL) is set      -> PostgreSQL  (the deployed VM)
#   * Otherwise                              -> local SQLite/SQLCipher (offline dev)

# SQLite / SQLCipher backend (local dev + migration source):
# Path to the SQLCipher-encrypted DB file (created automatically).
NOTES_DB_PATH=notes.db
# SQLCipher encryption key (passphrase) for the notes DB at rest.
# Generate a strong one with:  openssl rand -hex 32
SQLCIPHER_KEY=replace-with-a-strong-random-key

# PostgreSQL backend (Supabase). Setting DB_URL switches the store to Postgres.
# "Encrypted at rest" is provided by Supabase's managed AES-256 + TLS in transit
# (DB_SSL_REQUIRE). Tables are created in the DB_SCHEMA schema (default
# writer_app). Prefer DB_URL (session pooler :5432) for the app; DB_POOL_URL is
# the transaction pooler/pgbouncer (:6543).
# DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
# DB_POOL_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
# DB_SSL_REQUIRE=true
# DB_SCHEMA=writer_app
