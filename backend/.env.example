# =============================================================================
# DropNote — backend environment
#
# FORMAT MATTERS: write `KEY=value` with NO spaces around `=` and NO surrounding
# quotes. Locally python-dotenv is lenient, but in deployment these values are read
# by Docker Compose's stricter env_file parser — a line like
#   DATABASE_URL = "postgres://…"   (spaces + quotes)
# is read as an empty/garbled value there and breaks the VM. Keep it bare:
#   DATABASE_URL=postgres://…
# =============================================================================

# --- LiveKit ---
# v2.0 DEFAULT: self-hosted local server (docker compose up).
# Use your Mac's LAN IP (not localhost) so a physical iPhone can connect.
# Find it with: ipconfig getifaddr en0
LIVEKIT_URL=ws://192.168.1.104:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace-with-the-secret-in-livekit.yaml

# (v1.0 cloud option — still works, just swap these back in:)
# LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
# LIVEKIT_API_KEY=APIxxxxxxxxxxxx
# LIVEKIT_API_SECRET=your-livekit-cloud-secret

# --- Deepgram (STT + Aura TTS): https://console.deepgram.com ---
DEEPGRAM_API_KEY=your-deepgram-api-key

# --- Groq (LLM): https://console.groq.com/keys  (free tier) ---
GROQ_API_KEY=gsk_your-groq-api-key

# --- Postgres (auth + notes) ---
# A single Postgres instance (e.g. Supabase) holds BOTH auth data (`user_schema`
# schema) and the per-user notes (`writer_app` schema). Encryption at rest is handled
# by Postgres/Supabase. Point this at your instance — bare value, no quotes/spaces:
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Secret used to sign session JWTs. Generate with:  openssl rand -hex 32
AUTH_JWT_SECRET=replace-with-a-strong-random-key
# How long a login session stays valid (hours). Default 720 = 30 days.
AUTH_TOKEN_TTL_HOURS=720
# Shared secret for the no-UI POST /users endpoint (sent as the X-Admin-Token header).
# Generate with:  openssl rand -hex 32
ADMIN_SECRET=replace-with-a-strong-random-key
