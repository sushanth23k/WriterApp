# Secrets — never commit
.env
**/.env
!**/.env.example

# GCP deploy config (VM identity/IPs) — never commit
.deployenv
!.deployenv.example

# Python
backend/.venv/
__pycache__/
*.pyc

# Node / Expo
app/node_modules/
app/.expo/
app/dist/
app/ios/
app/android/
npm-debug.*
*.log

# Encrypted notes DB (v2.0) — never commit
*.db
*.db-shm
*.db-wal
backend/notes.db

# Local LiveKit dev config holds a dev secret — never commit
backend/livekit.yaml

# On-device model weights (STT/TTS) — large; downloaded per-machine via
# scripts/download_models.sh, never committed. See backend/LOCAL_INFERENCE.md.
models/
# Smoke-test audio output
backend/scripts/out/

# macOS
.DS_Store
